{
    "name": "caspernieuwenhuizen/talenttrack",
    "description": "Frontend-first modular youth football talent management system.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0+",
    "homepage": "https://github.com/caspernieuwenhuizen/talenttrack",
    "authors": [
        {
            "name": "Casper Nieuwenhuizen",
            "homepage": "https://github.com/caspernieuwenhuizen"
        }
    ],
    "support": {
        "issues": "https://github.com/caspernieuwenhuizen/talenttrack/issues",
        "source": "https://github.com/caspernieuwenhuizen/talenttrack"
    },
    "require": {
        "php": ">=7.4",
        "phpoffice/phpspreadsheet": "^1.29",
        "dompdf/dompdf": "^2.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "TT\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TT\\Tests\\PhpStanRules\\": "tests/PhpStanRules/",
            "TT\\Tests\\Php\\": "tests/php/"
        }
    },
    "scripts": {
        "lint": "find src -name '*.php' -print0 | xargs -0 -n1 php -l",
        "analyse": "phpstan analyse --memory-limit=1G",
        "test:php": "phpunit"
    }
}
