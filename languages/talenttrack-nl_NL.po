# v2.6.3 Migrations admin page
msgid "Database Migrations"
msgstr "Database-migraties"

msgid "Migrations"
msgstr "Migraties"

msgid "TalentTrack uses versioned database migrations to evolve its schema safely. This page shows every migration shipped with the plugin and its status."
msgstr "TalentTrack gebruikt versiegebaseerde database-migraties om het databaseschema veilig te ontwikkelen. Deze pagina toont elke migratie die is meegeleverd met de plugin en de bijbehorende status."

msgid "Warning: migrations recorded as applied but missing from disk:"
msgstr "Waarschuwing: migraties zijn als toegepast geregistreerd, maar de bestanden ontbreken op schijf:"

msgid "This usually means migration files were deleted or never copied during manual installation. No action required unless you need to re-apply."
msgstr "Dit betekent meestal dat migratiebestanden zijn verwijderd of niet zijn meegekopieerd tijdens een handmatige installatie. Geen actie vereist, tenzij u opnieuw wilt toepassen."

msgid "%d pending migration"
msgid_plural "%d pending migrations"
msgstr[0] "%d migratie in behandeling"
msgstr[1] "%d migraties in behandeling"

msgid "Pending migrations typically ship new schema changes required by recent features. Apply them to keep your database in sync with the plugin code."
msgstr "Migraties in behandeling bevatten doorgaans nieuwe schemawijzigingen die nodig zijn voor recente functies. Voer ze uit om uw database gelijk te houden met de plugincode."

msgid "Run All Pending Migrations"
msgstr "Alle openstaande migraties uitvoeren"

msgid "Database is up to date."
msgstr "Database is up-to-date."

msgid "%d migration applied."
msgid_plural "%d migrations applied."
msgstr[0] "%d migratie toegepast."
msgstr[1] "%d migraties toegepast."

msgid "All Migrations"
msgstr "Alle migraties"

msgid "Status"
msgstr "Status"

msgid "Migration"
msgstr "Migratie"

msgid "Applied At"
msgstr "Toegepast op"

msgid "Actions"
msgstr "Acties"

msgid "Pending"
msgstr "In behandeling"

msgid "Run"
msgstr "Uitvoeren"

msgid "No migrations found."
msgstr "Geen migraties gevonden."

msgid "Diagnostic Information"
msgstr "Diagnostische informatie"

msgid "Migrations directory"
msgstr "Map met migraties"

msgid "(directory not found!)"
msgstr "(map niet gevonden!)"

msgid "Tracking table"
msgstr "Volgsysteemtabel"

msgid "Tracking table does not exist yet."
msgstr "De volgsysteemtabel bestaat nog niet."

msgid "Plugin version"
msgstr "Plugin-versie"

msgid "Migration %s was already applied."
msgstr "Migratie %s was al toegepast."

msgid "Migration %1$s applied successfully in %2$dms."
msgstr "Migratie %1$s met succes toegepast in %2$dms."

msgid "Migration %s failed."
msgstr "Migratie %s is mislukt."

# Dashboard pending-migration warning
msgid "TalentTrack: database migrations pending."
msgstr "TalentTrack: database-migraties in behandeling."

msgid "%d migration is waiting to be applied. Some features may not work until you apply it."
msgid_plural "%d migrations are waiting to be applied. Some features may not work until you apply them."
msgstr[0] "%d migratie wacht op uitvoering. Sommige functies werken mogelijk pas nadat u deze toepast."
msgstr[1] "%d migraties wachten op uitvoering. Sommige functies werken mogelijk pas nadat u deze toepast."

msgid "Review and Apply"
msgstr "Bekijken en toepassen"

# Common
msgid "Unauthorized"
msgstr "Geen toegang"
