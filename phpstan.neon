includes:
    # Baseline file grandfathers existing issues so CI can be green from day one.
    # New code must pass clean; existing issues are cleaned up incrementally.
    - phpstan-baseline.neon

parameters:
    level: 8
    paths:
        - src
    bootstrapFiles:
        - vendor/szepeviktor/phpstan-wordpress/bootstrap.php
    ignoreErrors: []
